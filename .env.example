DISABLE_ESLINT_PLUGIN=true
ESLINT_NO_DEV_ERRORS=true
SKIP_PREFLIGHT_CHECK=true

PORT=5000
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── AI (use ONE stack) ─────────────────────────────────────────────────────
# Option A — Azure OpenAI (resource URL only; optional /openai/v1 suffix is stripped):
#   AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
#   AZURE_OPENAI_KEY=...
#   AZURE_OPENAI_API_VERSION=2024-10-21   # required by Azure REST; override if your region needs a newer preview
#   AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini   # must match your deployment *name* in Azure
#   AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-4o   # optional override for deep analysis only
#
# Option B — api.openai.com:
OPENAI_API_KEY=sk-proj-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ANALYSIS_MODEL=gpt-4o

# Neon Auth — required for sign-in/sign-up (backend)
NEON_AUTH_URL=https://ep-xxx.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth

# Frontend API base (omit for CRA dev — uses /api proxy to localhost:5000)
# REACT_APP_API_URL=https://api.yoursite.com
# Local production build: optional comma-separated ports to probe for /api/health (default tries several):
# REACT_APP_API_PORT=5001,5000

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxx
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_ID_USD=price_xxxx
STRIPE_PRICE_ID_NGN=price_xxxx
