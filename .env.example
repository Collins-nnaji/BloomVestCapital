DISABLE_ESLINT_PLUGIN=true
ESLINT_NO_DEV_ERRORS=true
SKIP_PREFLIGHT_CHECK=true

PORT=5000
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── AI (use ONE stack) ─────────────────────────────────────────────────────
# Option A — Azure AI / Foundry style (OpenAI-compatible base path /openai/v1):
#   AZURE_OPENAI_ENDPOINT=https://your-resource.region.models.ai.azure.com
#   AZURE_OPENAI_KEY=...
#   AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
#   AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-4o   # optional override for deep analysis only
#
# Option B — api.openai.com:
OPENAI_API_KEY=sk-proj-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ANALYSIS_MODEL=gpt-4o

# Neon Auth — required for sign-in/sign-up (backend)
NEON_AUTH_URL=https://ep-xxx.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth

# Frontend: only if the API is not proxied from the CRA dev server (see package.json "proxy")
# REACT_APP_API_URL=https://api.yoursite.com

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxx
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_ID_USD=price_xxxx
STRIPE_PRICE_ID_NGN=price_xxxx
